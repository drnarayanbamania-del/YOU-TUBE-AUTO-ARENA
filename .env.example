# Vercel / serverless YouTube proxy
# Add this in local .env and in Vercel Project Settings → Environment Variables
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Server-side OpenAI storyboard generator
# Add only on the server/Vercel environment, never in frontend code.
OPENAI_API_KEY=your_openai_api_key_here

# Server-side Sarvam AI text-to-speech
# Add only on the server/Vercel environment, never in frontend code.
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_API_BASE_URL=https://api.sarvam.ai
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SPEAKER=meera
SARVAM_LANGUAGE_CODE=hi-IN
SARVAM_SAMPLE_RATE=22050

# Optional client-side fallback only for local experiments.
# Do not use this in production if you want to keep the key private.
VITE_YOUTUBE_API_KEY=
